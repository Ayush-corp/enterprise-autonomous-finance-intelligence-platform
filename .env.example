APP_NAME="Autonomous Investing Agent"
APP_VERSION="2.0.0"
ENVIRONMENT="development"
DEBUG=true

LLM_PROVIDER="mock"
LLM_MODEL="gpt-4o-mini"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_API_KEY=""
ENABLE_LIVE_LLM=false

MARKET_PROVIDER="auto"
MASSIVE_API_KEY=""
MASSIVE_BASE_URL="https://api.polygon.io"
# MARKET_PROVIDER can be "mock", "auto", "massive", or "yfinance".
# auto routes US stocks to Massive/Polygon and Indian stocks to yfinance.

NEWS_PROVIDER="mock"
NEWS_API_KEY=""

LOG_LEVEL="INFO"

SQLITE_PATH="data/investoros.sqlite3"
ENABLE_SCHEDULER=false
SCHEDULER_TIMEZONE="Asia/Kolkata"
DAILY_PREDICTION_TIME="16:15"
DATA_REFRESH_TIME="08:30"
EVALUATION_TIME="17:00"
PREDICTION_HORIZONS="1D,7D,30D,90D"
DEFAULT_BENCHMARK_SYMBOL="^NSEI"
ANALYSIS_CACHE_TTL_SECONDS=300
